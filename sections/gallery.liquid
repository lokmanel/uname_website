<section class="section-gallery" style="padding-top: {{ section.settings.padding_top | default: 64 }}px; padding-bottom: {{ section.settings.padding_bottom | default: 96 }}px;">
  {%- if section.settings.title != blank or section.settings.description != blank -%}
    <div class="section-gallery__header">
      {%- if section.settings.title != blank -%}
        <h2 class="section-gallery__title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <div class="section-gallery__desc" style="font-size: {{ section.settings.desc_size | default: 20 }}px; max-width: {{ section.settings.desc_width | default: 480 }}px; text-align: {{ section.settings.desc_align | default: 'left' }};">{{ section.settings.description }}</div>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="gallery-grid">
      {%- for block in section.blocks -%}
        <div class="gallery-grid__item gallery-grid__item--{{ forloop.index }}" {{ block.shopify_attributes }}>
          <a
            href="{{ block.settings.link | default: '#' }}"
            class="gallery-grid__link"
            {%- if block.settings.link == blank %} tabindex="-1" aria-hidden="true"{% endif %}>

            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 1200 }}"
                alt="{{ block.settings.alt | default: block.settings.image.alt | default: '' }}"
                loading="lazy"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}">
            {%- else -%}
              <div class="gallery-grid__placeholder"></div>
            {%- endif -%}

            {%- if block.settings.project_name != blank -%}
              <div class="gallery-grid__overlay">
                <div class="gallery-grid__label">
                  <span class="gallery-grid__script">projet</span>
                  <span class="gallery-grid__name">{{ block.settings.project_name | upcase }}</span>
                </div>
              </div>
            {%- endif -%}

          </a>
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Galerie",
  "tag": "section",
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Texte alternatif"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lien (rend l'image cliquable)"
        },
        {
          "type": "text",
          "id": "project_name",
          "label": "Nom du projet (visible au hover)"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Galerie"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.</p>"
    },
    {
      "type": "range",
      "id": "desc_size",
      "label": "Taille du texte de description (px)",
      "min": 12,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "desc_width",
      "label": "Largeur du texte de description (px)",
      "min": 300,
      "max": 900,
      "step": 10,
      "unit": "px",
      "default": 480
    },
    {
      "type": "select",
      "id": "desc_align",
      "label": "Alignement du texte",
      "options": [
        { "value": "left", "label": "Gauche" },
        { "value": "center", "label": "Centré" },
        { "value": "right", "label": "Droite" }
      ],
      "default": "left"
    },
    { "type": "header", "content": "Espacement" },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Marge au-dessus (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Marge en dessous (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "paragraph",
      "content": "💡 Astuce : pour un rendu optimal, utilisez un multiple de 4 images (4, 8, 12, 16, 20...)."
    }
  ],
  "presets": [
    {
      "name": "Galerie",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ],
  "max_blocks": 50
}
{% endschema %}

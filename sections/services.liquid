<section class="section-services">
  <div class="section-services__header">
    <h2 class="section-services__title">{{ section.settings.title }}</h2>
    {%- if section.settings.description != blank -%}
      <div class="section-services__desc" style="font-size: {{ section.settings.desc_size | default: 20 }}px; max-width: {{ section.settings.desc_width | default: 480 }}px; text-align: {{ section.settings.desc_align | default: 'left' }};">{{ section.settings.description }}</div>
    {%- endif -%}
  </div>

  <div class="section-services__image-wrap">
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 2000 }}"
        alt="{{ section.settings.title }}"
        loading="lazy"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}">
    {%- else -%}
      <div class="section-services__placeholder"></div>
    {%- endif -%}

    {%- for block in section.blocks -%}
      <a
        href="{{ block.settings.link | default: '#' }}"
        class="hotspot"
        style="top:{{ block.settings.pos_y }}%;left:{{ block.settings.pos_x }}%;"
        {{ block.shopify_attributes }}
      >
        <span class="hotspot__dot"></span>
        <span class="hotspot__label">{{ block.settings.label }}</span>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Services",
  "tag": "section",
  "blocks": [
    {
      "type": "hotspot",
      "name": "Point d'intérêt",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Étiquette",
          "default": "Studio"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lien"
        },
        {
          "type": "range",
          "id": "pos_x",
          "label": "Position horizontale (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50
        },
        {
          "type": "range",
          "id": "pos_y",
          "label": "Position verticale (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Services"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.</p>"
    },
    {
      "type": "range",
      "id": "desc_size",
      "label": "Taille du texte de description (px)",
      "min": 12,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "desc_width",
      "label": "Largeur du texte de description (px)",
      "min": 300,
      "max": 900,
      "step": 10,
      "unit": "px",
      "default": 480
    },
    {
      "type": "select",
      "id": "desc_align",
      "label": "Alignement du texte",
      "options": [
        { "value": "left", "label": "Gauche" },
        { "value": "center", "label": "Centré" },
        { "value": "right", "label": "Droite" }
      ],
      "default": "left"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image de fond"
    }
  ],
  "presets": [
    {
      "name": "Services",
      "blocks": [
        {
          "type": "hotspot",
          "settings": { "label": "Travaux", "pos_x": 37, "pos_y": 35 }
        },
        {
          "type": "hotspot",
          "settings": { "label": "Café", "pos_x": 73, "pos_y": 47 }
        },
        {
          "type": "hotspot",
          "settings": { "label": "Studio", "pos_x": 14, "pos_y": 68 }
        }
      ]
    }
  ]
}
{% endschema %}

<section class="service-block {% if section.settings.reverse %}service-block--reverse{% endif %}">

  {%- if section.settings.title != blank -%}
    <h2 class="service-block__title">{{ section.settings.title }}</h2>
  {%- endif -%}

  <div class="service-block__content">

    {%- assign img_count = 0 -%}
    {%- if section.settings.image_1 != blank -%}{%- assign img_count = img_count | plus: 1 -%}{%- endif -%}
    {%- if section.settings.image_2 != blank -%}{%- assign img_count = img_count | plus: 1 -%}{%- endif -%}
    {%- if section.settings.image_3 != blank -%}{%- assign img_count = img_count | plus: 1 -%}{%- endif -%}

    <div class="service-block__images service-block__images--count-{{ img_count }}" style="--sb-ratio: {{ section.settings.images_ratio | default: '3 / 2' }};">
      {%- if img_count == 0 -%}
        {%- for i in (1..3) -%}
          <div class="service-block__img service-block__img--{{ i }}">
            <div class="service-block__placeholder"></div>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..3) -%}
          {%- assign img_key = 'image_' | append: i -%}
          {%- assign name_key = 'project_name_' | append: i -%}
          {%- assign link_key = 'link_' | append: i -%}
          {%- if section.settings[img_key] == blank -%}{%- continue -%}{%- endif -%}
          <div class="service-block__img{% if img_count == 3 %} service-block__img--{{ i }}{% endif %}">
            {%- if section.settings[link_key] != blank -%}
              <a href="{{ section.settings[link_key] }}" class="service-block__img-link">
            {%- endif -%}

            <img
              src="{{ section.settings[img_key] | image_url: width: 900 }}"
              alt="{{ section.settings[img_key].alt | default: '' }}"
              loading="lazy">

            {%- if section.settings[name_key] != blank -%}
              <div class="service-block__overlay">
                <div class="service-block__label">
                  <span class="service-block__script">projet</span>
                  <span class="service-block__name">{{ section.settings[name_key] | upcase }}</span>
                </div>
              </div>
            {%- endif -%}

            {%- if section.settings[link_key] != blank -%}
              </a>
            {%- endif -%}
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    <div class="service-block__text service-block__text--align-{{ section.settings.text_align | default: 'left' }} service-block__text--pos-{{ section.settings.text_position | default: 'middle' }}">
      {%- if section.settings.description != blank -%}
        <div class="service-block__desc" style="font-size: {{ section.settings.desc_size | default: 16 }}px;">{{ section.settings.description }}</div>
      {%- endif -%}
      {%- if section.settings.btn_text != blank -%}
        <a class="service-block__btn" href="{{ section.settings.btn_url | default: '#' }}">
          {{ section.settings.btn_text }}
        </a>
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Bloc service",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Audit"
    },
    {
      "type": "checkbox",
      "id": "reverse",
      "label": "Inverser (texte à gauche, images à droite)",
      "default": false
    },
    { "type": "header", "content": "Images" },
    {
      "type": "paragraph",
      "content": "💡 Laissez une image vide pour l'enlever : la mise en page s'adapte automatiquement (3, 2 ou 1 image)."
    },
    {
      "type": "select",
      "id": "images_ratio",
      "label": "Proportions du bloc images",
      "options": [
        { "value": "3 / 2", "label": "Paysage 3:2 (défaut)" },
        { "value": "4 / 3", "label": "Paysage 4:3" },
        { "value": "16 / 9", "label": "Panoramique 16:9" },
        { "value": "1 / 1", "label": "Carré 1:1" }
      ],
      "default": "3 / 2"
    },
    { "type": "header", "content": "Image 1 (grande, en haut)" },
    { "type": "image_picker", "id": "image_1", "label": "Image" },
    { "type": "text", "id": "project_name_1", "label": "Nom du projet (visible au hover)" },
    { "type": "url", "id": "link_1", "label": "Lien" },
    { "type": "header", "content": "Image 2 (bas gauche)" },
    { "type": "image_picker", "id": "image_2", "label": "Image" },
    { "type": "text", "id": "project_name_2", "label": "Nom du projet (visible au hover)" },
    { "type": "url", "id": "link_2", "label": "Lien" },
    { "type": "header", "content": "Image 3 (bas droite)" },
    { "type": "image_picker", "id": "image_3", "label": "Image" },
    { "type": "text", "id": "project_name_3", "label": "Nom du projet (visible au hover)" },
    { "type": "url", "id": "link_3", "label": "Lien" },
    { "type": "header", "content": "Texte" },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.</p>"
    },
    {
      "type": "range",
      "id": "desc_size",
      "label": "Taille du texte de description (px)",
      "min": 12,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Alignement du texte",
      "options": [
        { "value": "left", "label": "Gauche" },
        { "value": "center", "label": "Centré" },
        { "value": "right", "label": "Droite" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "text_position",
      "label": "Position verticale du texte",
      "options": [
        { "value": "top", "label": "En haut" },
        { "value": "middle", "label": "Centré" },
        { "value": "bottom", "label": "En bas" }
      ],
      "default": "middle"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Texte du bouton",
      "default": "En savoir plus"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Lien du bouton"
    }
  ],
  "presets": [
    { "name": "Bloc service" }
  ]
}
{% endschema %}

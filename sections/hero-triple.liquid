<section class="hero-triple">

  {%- for i in (1..3) -%}
    {%- assign img_key   = 'panel' | append: i | append: '_image' -%}
    {%- assign script_key = 'panel' | append: i | append: '_script' -%}
    {%- assign title_key = 'panel' | append: i | append: '_title' -%}
    {%- assign text_key  = 'panel' | append: i | append: '_text' -%}
    {%- assign link_key  = 'panel' | append: i | append: '_link' -%}
    {%- assign cta_key   = 'panel' | append: i | append: '_cta' -%}

    {%- comment -%} Bouton affiché si son texte est renseigné, sinon panneau cliquable {%- endcomment -%}
    {%- assign panel_clickable = false -%}
    {%- if section.settings[cta_key] == blank and section.settings[link_key] != blank -%}
      {%- assign panel_clickable = true -%}
    {%- endif -%}

    {%- if panel_clickable -%}
      <a class="hero-triple__panel" href="{{ section.settings[link_key] }}">
    {%- else -%}
      <div class="hero-triple__panel">
    {%- endif -%}
      {%- if section.settings[img_key] != blank -%}
        <img
          class="hero-triple__bg"
          src="{{ section.settings[img_key] | image_url: width: 900 }}"
          alt="{{ section.settings[title_key] }}"
          loading="{{ forloop.first | replace: 'true', 'eager' | replace: 'false', 'lazy' }}"
          fetchpriority="{{ forloop.first | replace: 'true', 'high' | replace: 'false', 'auto' }}">
      {%- else -%}
        <div class="hero-triple__bg" style="background: #b5ac9e;"></div>
      {%- endif -%}

      <div class="hero-triple__overlay"></div>

      <div class="hero-triple__content">
        <div class="hero-triple__label-wrapper">
          {%- if section.settings[script_key] != blank -%}
            <span class="hero-triple__script">{{ section.settings[script_key] }}</span>
          {%- endif -%}
          {%- if section.settings[title_key] != blank -%}
            <h2 class="hero-triple__title">{{ section.settings[title_key] }}</h2>
          {%- endif -%}
        </div>
        {%- if section.settings[text_key] != blank -%}
          <p class="hero-triple__text" style="font-size: {{ section.settings.text_size | default: 15 }}px;">{{ section.settings[text_key] | newline_to_br }}</p>
        {%- endif -%}
        {%- if section.settings[cta_key] != blank -%}
          <a href="{{ section.settings[link_key] | default: '#' }}" class="hero-triple__btn">
            {{ section.settings[cta_key] }}
          </a>
        {%- endif -%}
      </div>
    {%- if panel_clickable -%}</a>{%- else -%}</div>{%- endif -%}

  {%- endfor -%}

</section>

{% schema %}
{
  "name": "Hero triple",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Options" },
    {
      "type": "range",
      "id": "text_size",
      "label": "Taille du texte (px)",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 15
    },

    { "type": "header", "content": "Panneau 1" },
    { "type": "image_picker", "id": "panel1_image", "label": "Image" },
    { "type": "text", "id": "panel1_script", "label": "Texte script", "default": "l'" },
    { "type": "text", "id": "panel1_title", "label": "Titre", "default": "AUDIT" },
    { "type": "textarea", "id": "panel1_text", "label": "Texte (optionnel)" },
    { "type": "url",  "id": "panel1_link",  "label": "Lien", "info": "Sans bouton, tout le panneau devient cliquable via ce lien." },
    { "type": "text", "id": "panel1_cta",   "label": "Texte du bouton (laisser vide pour le masquer)" },

    { "type": "header", "content": "Panneau 2" },
    { "type": "image_picker", "id": "panel2_image", "label": "Image" },
    { "type": "text", "id": "panel2_script", "label": "Texte script", "default": "la" },
    { "type": "text", "id": "panel2_title",  "label": "Titre", "default": "CONCEPTION" },
    { "type": "textarea", "id": "panel2_text", "label": "Texte (optionnel)" },
    { "type": "url",  "id": "panel2_link",   "label": "Lien", "info": "Sans bouton, tout le panneau devient cliquable via ce lien." },
    { "type": "text", "id": "panel2_cta",    "label": "Texte du bouton (laisser vide pour le masquer)" },

    { "type": "header", "content": "Panneau 3" },
    { "type": "image_picker", "id": "panel3_image", "label": "Image" },
    { "type": "text", "id": "panel3_script", "label": "Texte script", "default": "les" },
    { "type": "text", "id": "panel3_title",  "label": "Titre", "default": "TRAVAUX" },
    { "type": "textarea", "id": "panel3_text", "label": "Texte (optionnel)" },
    { "type": "url",  "id": "panel3_link",   "label": "Lien", "info": "Sans bouton, tout le panneau devient cliquable via ce lien." },
    { "type": "text", "id": "panel3_cta",    "label": "Texte du bouton (laisser vide pour le masquer)" }
  ],
  "presets": [
    { "name": "Hero triple" }
  ]
}
{% endschema %}

<section class="hero-split">

  {%- comment -%} Panel gauche {%- endcomment -%}
  {%- assign panel1_clickable = false -%}
  {%- if section.settings.show_buttons != true and section.settings.panel1_link != blank -%}
    {%- assign panel1_clickable = true -%}
  {%- endif -%}
  {%- if panel1_clickable -%}
    <a class="hero-split__panel" href="{{ section.settings.panel1_link }}">
  {%- else -%}
    <div class="hero-split__panel">
  {%- endif -%}
    {%- if section.settings.panel1_image != blank -%}
      <img
        class="hero-split__bg"
        src="{{ section.settings.panel1_image | image_url: width: 1400 }}"
        alt="{{ section.settings.panel1_title }}"
        loading="eager"
        fetchpriority="high"
        width="960" height="1080">
    {%- else -%}
      <div class="hero-split__bg" style="background:#c9c1b9;"></div>
    {%- endif -%}
    <div class="hero-split__overlay"></div>
    <div class="hero-split__content">
      <div class="hero-split__label-wrapper">
        {%- if section.settings.panel1_script != blank -%}
          <span class="hero-split__script">{{ section.settings.panel1_script }}</span>
        {%- endif -%}
        <h2 class="hero-split__title">{{ section.settings.panel1_title }}</h2>
      </div>
      {%- if section.settings.panel1_text != blank -%}
        <p class="hero-split__text" style="font-size: {{ section.settings.text_size | default: 16 }}px;">{{ section.settings.panel1_text | newline_to_br }}</p>
      {%- endif -%}
      {%- if section.settings.show_buttons -%}
        <a href="{{ section.settings.panel1_link }}" class="hero-split__btn">
          {{ section.settings.panel1_cta | default: 'Je découvre' }}
        </a>
      {%- endif -%}
    </div>
  {%- if panel1_clickable -%}</a>{%- else -%}</div>{%- endif -%}

  {%- comment -%} Panel droit {%- endcomment -%}
  {%- assign panel2_clickable = false -%}
  {%- if section.settings.show_buttons != true and section.settings.panel2_link != blank -%}
    {%- assign panel2_clickable = true -%}
  {%- endif -%}
  {%- if panel2_clickable -%}
    <a class="hero-split__panel" href="{{ section.settings.panel2_link }}">
  {%- else -%}
    <div class="hero-split__panel">
  {%- endif -%}
    {%- if section.settings.panel2_image != blank -%}
      <img
        class="hero-split__bg"
        src="{{ section.settings.panel2_image | image_url: width: 1400 }}"
        alt="{{ section.settings.panel2_title }}"
        loading="eager"
        width="960" height="1080">
    {%- else -%}
      <div class="hero-split__bg" style="background:#b5ac9e;"></div>
    {%- endif -%}
    <div class="hero-split__overlay"></div>
    <div class="hero-split__content">
      <div class="hero-split__label-wrapper">
        {%- if section.settings.panel2_script != blank -%}
          <span class="hero-split__script">{{ section.settings.panel2_script }}</span>
        {%- endif -%}
        <h2 class="hero-split__title">{{ section.settings.panel2_title }}</h2>
      </div>
      {%- if section.settings.panel2_text != blank -%}
        <p class="hero-split__text" style="font-size: {{ section.settings.text_size | default: 16 }}px;">{{ section.settings.panel2_text | newline_to_br }}</p>
      {%- endif -%}
      {%- if section.settings.show_buttons -%}
        <a href="{{ section.settings.panel2_link }}" class="hero-split__btn">
          {{ section.settings.panel2_cta | default: 'Je découvre' }}
        </a>
      {%- endif -%}
    </div>
  {%- if panel2_clickable -%}</a>{%- else -%}</div>{%- endif -%}

</section>

{% schema %}
{
  "name": "Hero divisé",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Options"
    },
    {
      "type": "checkbox",
      "id": "show_buttons",
      "label": "Afficher les boutons",
      "info": "Si masqué, tout le panneau devient cliquable via son lien.",
      "default": false
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Taille du texte (px)",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Panneau gauche"
    },
    {
      "type": "image_picker",
      "id": "panel1_image",
      "label": "Image gauche"
    },
    {
      "type": "text",
      "id": "panel1_script",
      "label": "Texte script (ex : le)",
      "default": "le"
    },
    {
      "type": "text",
      "id": "panel1_title",
      "label": "Titre",
      "default": "STUDIO"
    },
    {
      "type": "textarea",
      "id": "panel1_text",
      "label": "Texte (optionnel)"
    },
    {
      "type": "url",
      "id": "panel1_link",
      "label": "Lien"
    },
    {
      "type": "text",
      "id": "panel1_cta",
      "label": "Texte du bouton",
      "default": "Je découvre"
    },
    {
      "type": "header",
      "content": "Panneau droit"
    },
    {
      "type": "image_picker",
      "id": "panel2_image",
      "label": "Image droite"
    },
    {
      "type": "text",
      "id": "panel2_script",
      "label": "Texte script",
      "default": "le"
    },
    {
      "type": "text",
      "id": "panel2_title",
      "label": "Titre",
      "default": "CAFÉ"
    },
    {
      "type": "textarea",
      "id": "panel2_text",
      "label": "Texte (optionnel)"
    },
    {
      "type": "url",
      "id": "panel2_link",
      "label": "Lien"
    },
    {
      "type": "text",
      "id": "panel2_cta",
      "label": "Texte du bouton",
      "default": "Je découvre"
    }
  ],
  "presets": [
    {
      "name": "Hero divisé"
    }
  ]
}
{% endschema %}
